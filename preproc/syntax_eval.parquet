xt-right" dir="auto"><!--[-1--><!--[7-->0<!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="1" data-column-index="12"><div class="line-clamp-2 "><!--[--><!--[-1--><div class="text-right" dir="auto"><!--[-1--><!--[7-->2<!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="1" data-column-index="13"><div class="line-clamp-2 "><!--[--><!--[-1--><div class="text-right" dir="auto"><!--[-1--><!--[7-->71.42589<!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><!--]--></tr><tr class="group cursor-pointer space-x-4 divide-x border-b outline-offset-[-2px] odd:bg-gray-50 hover:bg-gray-100 dark:odd:bg-gray-925 dark:hover:bg-gray-850  last:border-none" tabindex="0" data-row-idx="2" data-table-row-index="2"><!--[--><td class="group relative min-w-fit max-w-sm break-words p-2" data-table-row-index="2" data-column-index="0"><div class="line-clamp-2 "><!--[--><!--[-1--><div dir="auto"><!--[-1--><!--[10--><div><!--[-1--><!--]--> <span class="block ">0009e4e7828d2e2f819c307b81bf8c7a</span></div> <!--[-1--><!--]--><!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="2" data-column-index="1"><div class="line-clamp-2 "><!--[--><!--[-1--><div dir="auto"><!--[-1--><!--[10--><div><!--[-1--><!--]--> <span class="block ">gpt-4o-2024-05-13</span></div> <!--[-1--><!--]--><!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="2" data-column-index="2"><div class="line-clamp-2 "><!--[--><!--[-1--><div dir="auto"><!--[-1--><!--[10--><div><!--[-1--><!--]--> <span class="block ">Give me 10 python question for interview related to list and dictionary and pandas</span></div> <!--[-1--><!--]--><!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="2" data-column-index="3"><div class="line-clamp-2 "><!--[--><!--[-1--><div dir="auto"><!--[-1--><!--[10--><div><!--[-1--><!--]--> <span class="block ">Certainly! Here are 10 Python interview questions related to lists and dictionaries as well as the pandas library:

### Lists and Dictionaries

1. **List Manipulation:** How would you remove duplicates from a list while preserving the order?

2. **Dictionary Comprehension:** Explain with an example how you can create a dictionary comprehension from a list of tuples where each tuple has two elements: a key and a value.

3. **List vs. Dictionary:** Compare lists and dictionaries. When would you use one over the other? Provide examples.

4. **Finding Dictionary Keys:** How do you check if a key exists in a dictionary? Provide at least two different methods.

5. **Nested Dictionary:** Write a function that flattens a nested dictionary, i.e., converts it into a single-level dictionary with compound keys.

6. **Defaultdict and Counter:** Explain the `defaultdict` and `Counter` classes from the `collections` module with examples of their usage.

7. **List and Dictionary Performance:** Discuss the time complexity of basic operations (insert, delete, lookup) for lists and dictionaries.

### Pandas

8. **Creating DataFrames:** How would you create a Pandas DataFrame from a dictionary of lists? Provide a sample dictionary and its resulting DataFrame.

9. **Data Cleaning:** Describe how you’d handle missing values in a Pandas DataFrame. Mention at least three strategies.

10. **GroupBy Operations:** Given a DataFrame, demonstrate how you would use the `groupby` function to calculate the mean of a particular column for each group of another column.


### Sample Answers

#### List Manipulation Example
```python
# Removing duplicates while preserving order
def remove_duplicates(lst):
    seen = set()
    return [x for x in lst if not (x in seen or seen.add(x))]

# Example usage
nums = [1, 2, 3, 2, 1, 4, 5]
print(remove_duplicates(nums))  # Output: [1, 2, 3, 4, 5]
```

#### Creating DataFrames Example
```python
import pandas as pd

# Creating DataFrame from dictionary of lists
data = {
    'A': [1, 2, 3],
    'B': [4, 5, 6]
}
df = pd.DataFrame(data)
print(df)
```

#### Data Cleaning Example
```python
import pandas as pd
import numpy as np

# Sample DataFrame with missing values
data = {
    'A': [1, 2, np.nan],
    'B': [4, np.nan, 6]
}
df = pd.DataFrame(data)

# 1. Drop rows with any missing values
df_dropna = df.dropna()

# 2. Fill missing values with a constant (e.g., 0)
df_fillna = df.fillna(0)

# 3. Fill missing values with the mean of the column
df_fill_mean = df.apply(lambda x: x.fillna(x.mean()), axis=0)

print(df_dropna)
print(df_fillna)
print(df_fill_mean)
```</span></div> <!--[-1--><!--]--><!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="2" data-column-index="4"><div class="line-clamp-2 "><!--[--><!--[-1--><div dir="auto"><!--[-1--><!--[10--><div><!--[-1--><!--]--> <span class="block "># Removing duplicates while preserving order
def remove_duplicates(lst):
    seen = set()
    return [x for x in lst if not (x in seen or seen.add(x))]

# Example usage
nums = [1, 2, 3, 2, 1, 4, 5]
print(remove_duplicates(nums))  # Output: [1, 2, 3, 4, 5]


