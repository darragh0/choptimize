app = Flask(__name__)

# Global click counter
click_count = 0

# HTML template embedded within Python code
HTML_TEMPLATE = """
&lt;!DOCTYPE html>
&lt;html>
&lt;head>
  &lt;title>Click Counter&lt;/title>
  &lt;script src="https://telegram.org/js/telegram-web-app.js">&lt;/script>
  &lt;style>
