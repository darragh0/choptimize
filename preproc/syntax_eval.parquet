            p.value::jsonb->>'message' AS message,
            p.value::jsonb->>'subject' AS subject,
            p.value::jsonb->>'files' AS files,
            to_timestamp(split_part({board}.zeit, 'Z', 1), 'YYYY-MM-DD"T"HH24:MI:SS.MS') AS date
        FROM {board}
        CROSS JOIN LATERAL jsonb_each({board}.voll::jsonb->'posts') AS p(key, value)
        WHERE {board}.voll ~ '^\\s*\\{\\{'   -- Ensure 'voll' starts with '{{'
          AND jsonb_typeof({board}.voll::jsonb) = 'object'
          AND jsonb_typeof({board}.voll::jsonb->'posts') = 'object'
          AND (p.value::jsonb->>'message' IS NOT NULL 
               OR p.value::jsonb->>'subject' IS NOT NULL);
        ''', (board,))
    
    connection.commit()

    # Set up triggers for each board
    for board in boards:
        # Drop existing triggers if they exist
        cursor.execute(f'''
        DROP TRIGGER IF EXISTS {board}_insert_trigger ON {board};
        DROP TRIGGER IF EXISTS {board}_update_trigger ON {board};
        DROP TRIGGER IF EXISTS {board}_delete_trigger ON {board};
        ''')
        connection.commit()

        # Define the trigger functions with appropriate SQL code
        # Replace '%%%' placeholders with actual trigger function bodies as needed

        # Example for INSERT trigger function
        cursor.execute(f'''
        CREATE OR REPLACE FUNCTION {board}_insert_trigger_fn() RETURNS trigger AS $$
        BEGIN
            -- Your INSERT trigger logic here
            -- For example, insert into messages_fts as done above
            -- Make sure to handle JSON parsing safely
            IF TRIM(NEW.voll) LIKE '{{{{%' THEN
                BEGIN
                    INSERT INTO messages_fts (id1, board, message, subject, files, date)
                    VALUES (
                        NEW.id,
                        TG_TABLE_NAME,
                        NEW.voll::jsonb->>'message',
                        NEW.voll::jsonb->>'subject',
                        NEW.voll::jsonb->>'files',
                        to_timestamp(split_part(NEW.zeit, 'Z', 1), 'YYYY-MM-DD"T"HH24:MI:SS.MS')
                    );
                EXCEPTION WHEN others THEN
                    -- Handle JSON parsing errors or other exceptions
                    RAISE NOTICE 'Invalid JSON in voll for id %', NEW.id;
                END;
            END IF;
            RETURN NEW;
        END
        $$ LANGUAGE plpgsql;

        CREATE TRIGGER {board}_insert_trigger
        AFTER INSERT ON {board}
        FOR EACH ROW EXECUTE PROCEDURE {board}_insert_trigger_fn();
        ''')
        connection.commit()

        # Example for UPDATE trigger function
        cursor.execute(f'''
        CREATE OR REPLACE FUNCTION {board}_update_trigger_fn() RETURNS trigger AS $$
        BEGIN
            -- Your UPDATE trigger logic here
            -- Similar to INSERT, handle updates safely
            IF TRIM(NEW.voll) LIKE '{{{{%' THEN
                BEGIN
                    UPDATE messages_fts
                    SET 
                        message = NEW.voll::jsonb->>'message',
                        subject = NEW.voll::jsonb->>'subject',
                        files = NEW.voll::jsonb->>'files',
                        date = to_timestamp(split_part(NEW.zeit, 'Z', 1), 'YYYY-MM-DD"T"HH24:MI:SS.MS')
                    WHERE id1 = NEW.id;
                EXCEPTION WHEN others THEN
                    RAISE NOTICE 'Invalid JSON in voll for id %', NEW.id;
                END;
            ELSE
                DELETE FROM messages_fts WHERE id1 = NEW.id;
            END IF;
            RETURN NEW;
        END
        $$ LANGUAGE plpgsql;

        CREATE TRIGGER {board}_update_trigger
        AFTER UPDATE ON {board}
        FOR EACH ROW EXECUTE PROCEDURE {board}_update_trigger_fn();
        ''')
        connection.commit()

        # Example for DELETE trigger function
        cursor.execute(f'''
        CREATE OR REPLACE FUNCTION {board}_delete_trigger_fn() RETURNS trigger AS $$
        BEGIN
            -- Your DELETE trigger logic here
            DELETE FROM messages_fts WHERE id1 = OLD.id;
            RETURN OLD;
        END
        $$ LANGUAGE plpgsql;

        CREATE TRIGGER {board}_delete_trigger
        AFTER DELETE ON {board}
        FOR EACH ROW EXECUTE PROCEDURE {board}_delete_trigger_fn();
        ''')
        connection.commit()

    cursor.close()
    print('completed setup_fts')
</span></div> <!--[-1--><!--]--><!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="7" data-column-index="5"><div class="line-clamp-2 "><!--[--><!--[-1--><div class="text-right" dir="auto"><!--[-1--><!--[7-->false<!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="7" data-column-index="6"><div class="line-clamp-2 "><!--[--><!--[-1--><div class="text-right" dir="auto"><!--[-1--><!--[7-->201<!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="7" data-column-index="7"><div class="line-clamp-2 "><!--[--><!--[-1--><div class="text-right" dir="auto"><!--[-1--><!--[7-->7<!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="7" data-column-index="8"><div class="line-clamp-2 "><!--[--><!--[-1--><div class="text-right" dir="auto"><!--[-1--><!--[7-->9<!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="7" data-column-index="9"><div class="line-clamp-2 "><!--[--><!--[-1--><div class="text-right" dir="auto"><!--[-1--><!--[7-->0<!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="7" data-column-index="10"><div class="line-clamp-2 "><!--[--><!--[-1--><div class="text-right" dir="auto"><!--[-1--><!--[7-->0<!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="7" data-column-index="11"><div class="line-clamp-2 "><!--[--><!--[-1--><div class="text-right" dir="auto"><!--[-1--><!--[7-->0<!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="7" data-column-index="12"><div class="line-clamp-2 "><!--[--><!--[-1--><div class="text-right" dir="auto"><!--[-1--><!--[7-->0<!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="7" data-column-index="13"><div class="line-clamp-2 "><!--[--><!--[-1--><div class="text-right" dir="auto"><!--[-1--><!--[7-->0<!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><!--]--></tr><tr class="group cursor-pointer space-x-4 divide-x border-b outline-offset-[-2px] odd:bg-gray-50 hover:bg-gray-100 dark:odd:bg-gray-925 dark:hover:bg-gray-850  last:border-none" tabindex="0" data-row-idx="8" data-table-row-index="8"><!--[--><td class="group relative min-w-fit max-w-sm break-words p-2" data-table-row-index="8" data-column-index="0"><div class="line-clamp-2 "><!--[--><!--[-1--><div dir="auto"><!--[-1--><!--[10--><div><!--[-1--><!--]--> <span class="block ">001d007add848586ccc81f2a86d12a31</span></div> <!--[-1--><!--]--><!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="8" data-column-index="1"><div class="line-clamp-2 "><!--[--><!--[-1--><div dir="auto"><!--[-1--><!--[10--><div><!--[-1--><!--]--> <span class="block ">gpt-4o-2024-08-06</span></div> <!--[-1--><!--]--><!--]--><!--]--></div><!--]--><!--]--></div> <!--[-1--><!--]--></td><td class="group relative min-w-fit max-w-sm break-words p-2 border-l" data-table-row-index="8" data-column-index="2"><div class="line-clamp-2 "><!--[--><!--[-1--><div dir="auto"><!--[-1--><!--[10--><div><!--[-1--><!--]--> <span class="block ">System: You are an assistant made for the purposes of helping the user with Blender, the 3